<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2010/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <Description>Subscriber Summary Report - StarHub Telecom</Description>
  <Author>Nikhil Sai</Author>
  <AutoRefresh>0</AutoRefresh>

  <DataSources>
    <DataSource Name="TelecomDW">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=.;Initial Catalog=TelecomDW;Integrated Security=True</ConnectString>
      </ConnectionProperties>
    </DataSource>
  </DataSources>

  <DataSets>
    <DataSet Name="SubscriberSummary">
      <Query>
        <DataSourceName>TelecomDW</DataSourceName>
        <CommandText>
          SELECT
            subscriber_id,
            full_name,
            plan_type,
            region,
            status,
            activation_date,
            tenure_months,
            total_bills,
            total_revenue
          FROM reporting.vw_SubscriberSummary
          ORDER BY total_revenue DESC
        </CommandText>
      </Query>
      <Fields>
        <Field Name="subscriber_id"><DataField>subscriber_id</DataField></Field>
        <Field Name="full_name"><DataField>full_name</DataField></Field>
        <Field Name="plan_type"><DataField>plan_type</DataField></Field>
        <Field Name="region"><DataField>region</DataField></Field>
        <Field Name="status"><DataField>status</DataField></Field>
        <Field Name="activation_date"><DataField>activation_date</DataField></Field>
        <Field Name="tenure_months"><DataField>tenure_months</DataField></Field>
        <Field Name="total_bills"><DataField>total_bills</DataField></Field>
        <Field Name="total_revenue"><DataField>total_revenue</DataField></Field>
      </Fields>
    </DataSet>
  </DataSets>

  <ReportParameters>
    <ReportParameter Name="Region">
      <DataType>String</DataType>
      <DefaultValue><Values><Value>All</Value></Values></DefaultValue>
      <Prompt>Select Region</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue><Value>All</Value><Label>All Regions</Label></ParameterValue>
          <ParameterValue><Value>North</Value><Label>North</Label></ParameterValue>
          <ParameterValue><Value>South</Value><Label>South</Label></ParameterValue>
          <ParameterValue><Value>East</Value><Label>East</Label></ParameterValue>
          <ParameterValue><Value>West</Value><Label>West</Label></ParameterValue>
          <ParameterValue><Value>Central</Value><Label>Central</Label></ParameterValue>
        </ParameterValues>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="Status">
      <DataType>String</DataType>
      <DefaultValue><Values><Value>All</Value></Values></DefaultValue>
      <Prompt>Subscriber Status</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue><Value>All</Value><Label>All</Label></ParameterValue>
          <ParameterValue><Value>ACTIVE</Value><Label>Active</Label></ParameterValue>
          <ParameterValue><Value>INACTIVE</Value><Label>Inactive</Label></ParameterValue>
        </ParameterValues>
      </ValidValues>
    </ReportParameter>
  </ReportParameters>

  <Body>
    <ReportItems>
      <Tablix Name="SubscriberTable">
        <TablixBody>
          <TablixColumns>
            <TablixColumn><Width>1.2in</Width></TablixColumn>
            <TablixColumn><Width>1.5in</Width></TablixColumn>
            <TablixColumn><Width>1in</Width></TablixColumn>
            <TablixColumn><Width>0.8in</Width></TablixColumn>
            <TablixColumn><Width>0.8in</Width></TablixColumn>
            <TablixColumn><Width>1in</Width></TablixColumn>
            <TablixColumn><Width>0.8in</Width></TablixColumn>
            <TablixColumn><Width>1in</Width></TablixColumn>
          </TablixColumns>
          <TablixRows>
            <TablixRow>
              <Height>0.25in</Height>
              <TablixCells>
                <TablixCell><CellContents><Textbox Name="H1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Subscriber ID</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Full Name</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Plan Type</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Region</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Status</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H6"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Tenure (Months)</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H7"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Total Bills</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H8"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Total Revenue</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
              </TablixCells>
            </TablixRow>
            <TablixRow>
              <Height>0.25in</Height>
              <TablixCells>
                <TablixCell><CellContents><Textbox Name="D1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!subscriber_id.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!full_name.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!plan_type.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!region.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!status.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D6"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!tenure_months.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D7"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!total_bills.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D8"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!total_revenue.Value,"C2")</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
              </TablixCells>
            </TablixRow>
          </TablixRows>
        </TablixBody>
        <DataSetName>SubscriberSummary</DataSetName>
      </Tablix>
    </ReportItems>
    <Height>4in</Height>
  </Body>
</Report>

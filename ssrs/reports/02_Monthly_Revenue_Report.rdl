<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2010/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <Description>Monthly Revenue Report - StarHub Telecom</Description>
  <Author>Nikhil Sai</Author>

  <DataSources>
    <DataSource Name="TelecomDW">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=.;Initial Catalog=TelecomDW;Integrated Security=True</ConnectString>
      </ConnectionProperties>
    </DataSource>
  </DataSources>

  <DataSets>
    <DataSet Name="MonthlyRevenue">
      <Query>
        <DataSourceName>TelecomDW</DataSourceName>
        <CommandText>
          SELECT
            bill_year,
            bill_month,
            plan_type,
            region,
            total_subscribers,
            total_billed,
            total_collected,
            total_outstanding,
            arpu
          FROM reporting.vw_MonthlyRevenue
          ORDER BY bill_year DESC, bill_month DESC
        </CommandText>
      </Query>
      <Fields>
        <Field Name="bill_year"><DataField>bill_year</DataField></Field>
        <Field Name="bill_month"><DataField>bill_month</DataField></Field>
        <Field Name="plan_type"><DataField>plan_type</DataField></Field>
        <Field Name="region"><DataField>region</DataField></Field>
        <Field Name="total_subscribers"><DataField>total_subscribers</DataField></Field>
        <Field Name="total_billed"><DataField>total_billed</DataField></Field>
        <Field Name="total_collected"><DataField>total_collected</DataField></Field>
        <Field Name="total_outstanding"><DataField>total_outstanding</DataField></Field>
        <Field Name="arpu"><DataField>arpu</DataField></Field>
      </Fields>
    </DataSet>
  </DataSets>

  <Body>
    <ReportItems>
      <Tablix Name="RevenueTable">
        <TablixBody>
          <TablixColumns>
            <TablixColumn><Width>0.6in</Width></TablixColumn>
            <TablixColumn><Width>0.6in</Width></TablixColumn>
            <TablixColumn><Width>1in</Width></TablixColumn>
            <TablixColumn><Width>0.8in</Width></TablixColumn>
            <TablixColumn><Width>0.9in</Width></TablixColumn>
            <TablixColumn><Width>1in</Width></TablixColumn>
            <TablixColumn><Width>1in</Width></TablixColumn>
            <TablixColumn><Width>1in</Width></TablixColumn>
            <TablixColumn><Width>0.8in</Width></TablixColumn>
          </TablixColumns>
          <TablixRows>
            <TablixRow>
              <Height>0.25in</Height>
              <TablixCells>
                <TablixCell><CellContents><Textbox Name="H1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Year</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Month</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Plan Type</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Region</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Subscribers</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H6"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Total Billed</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H7"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Collected</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H8"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Outstanding</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="H9"><Paragraphs><Paragraph><TextRuns><TextRun><Value>ARPU</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
              </TablixCells>
            </TablixRow>
            <TablixRow>
              <Height>0.25in</Height>
              <TablixCells>
                <TablixCell><CellContents><Textbox Name="D1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!bill_year.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!bill_month.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!plan_type.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!region.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!total_subscribers.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D6"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!total_billed.Value,"C2")</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D7"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!total_collected.Value,"C2")</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D8"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!total_outstanding.Value,"C2")</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="D9"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!arpu.Value,"C2")</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
              </TablixCells>
            </TablixRow>
          </TablixRows>
        </TablixBody>
        <DataSetName>MonthlyRevenue</DataSetName>
      </Tablix>
    </ReportItems>
    <Height>4in</Height>
  </Body>
</Report>
